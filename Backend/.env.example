# ─────────────────────────────────────────
# CareerPilot Backend — Environment Variables
# Copy this file to .env and fill in your values
# Never commit your actual .env file to git!
# ─────────────────────────────────────────

# ── Django Core ───────────────────────────
# Generate a strong secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-strong-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────
# Leave commented for SQLite (development)
# Uncomment and fill in for PostgreSQL (production on Render)
# DATABASE_URL=postgres://user:password@host:5432/careerpilot

# ── CORS ──────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ── AI / External APIs ────────────────────
# Get your free Gemini API key at: https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional ──────────────────────────────
# OPENAI_API_KEY=
